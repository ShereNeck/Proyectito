@{
    ViewData["Title"] = "Banco Argentum — Acceso";
    Layout = null;
    string tab = (ViewBag.Tab as string) ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --navy: #0D1B3E;
            --navy2: #1A3070;
            --gold: #C9A84C;
            --blue: #185FA5;
            --green: #16A34A;
            --red: #DC2626;
            --muted: #6B7A99;
        }

        body {
            font-family: 'DM Sans', system-ui, sans-serif;
            min-height: 100vh;
            background: linear-gradient(145deg, var(--navy) 0%, var(--navy2) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ─── Selector ─── */
        .selector-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.5rem;
            width: 100%;
            max-width: 380px;
            padding: 1.5rem;
        }

        .logo-box {
            width: 64px;
            height: 64px;
            background: var(--gold);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 32px rgba(201,168,76,0.35);
        }

            .logo-box img {
                width: 48px;
                height: 48px;
                object-fit: contain;
            }

        .selector-title {
            color: white;
            font-size: 1.6rem;
            font-weight: 700;
        }

        .selector-sub {
            color: rgba(255,255,255,0.45);
            font-size: 0.85rem;
        }

        .selector-card {
            background: white;
            border-radius: 20px;
            padding: 1.75rem 1.5rem;
            width: 100%;
            box-shadow: 0 24px 60px rgba(0,0,0,0.35);
        }

            .selector-card h4 {
                color: var(--navy);
                font-size: 0.95rem;
                font-weight: 600;
                text-align: center;
                margin-bottom: 1.25rem;
                opacity: .7;
            }

        .option-btn {
            display: flex;
            align-items: center;
            gap: 1rem;
            width: 100%;
            background: #F0F4FF;
            border: 1.5px solid #E0E7FF;
            border-radius: 14px;
            padding: 1rem 1.1rem;
            text-align: left;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
            margin-bottom: 0.75rem;
        }

            .option-btn:last-child {
                margin-bottom: 0;
            }

            .option-btn:hover {
                background: #E0E9FF;
                border-color: var(--blue);
                transform: translateY(-1px);
            }

        .option-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

            .option-icon.blue {
                background: var(--blue);
                color: white;
            }

            .option-icon.navy {
                background: var(--navy);
                color: white;
            }

        .option-text strong {
            display: block;
            color: var(--navy);
            font-size: 0.95rem;
            font-weight: 700;
        }

        .option-text small {
            color: var(--muted);
            font-size: 0.78rem;
        }

        .option-arrow {
            margin-left: auto;
            color: var(--muted);
            font-size: 1rem;
        }

        .selector-footer {
            color: rgba(255,255,255,0.25);
            font-size: 0.72rem;
            text-align: center;
        }

        /* ─── Formulario ─── */
        .form-wrap {
            width: 100%;
            max-width: 380px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.25rem;
        }

        .form-card {
            background: white;
            border-radius: 20px;
            padding: 1.75rem 1.75rem 1.5rem;
            width: 100%;
            box-shadow: 0 24px 60px rgba(0,0,0,0.35);
        }

        .form-card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1.5px solid #F3F4F6;
        }

        .form-card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .form-card-icon.blue {
                background: #EFF6FF;
            }

                .form-card-icon.blue svg {
                    color: var(--blue);
                }

            .form-card-icon.green {
                background: #F0FDF4;
            }

                .form-card-icon.green svg {
                    color: var(--green);
                }

        .form-card-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--navy);
        }

        .form-card-sub {
            font-size: 0.75rem;
            color: var(--muted);
        }

        .fg {
            margin-bottom: 0.85rem;
        }

            .fg label {
                display: block;
                font-size: 0.78rem;
                font-weight: 600;
                color: #374151;
                margin-bottom: 0.3rem;
            }

            .fg input {
                width: 100%;
                border: 1.5px solid #D1D5DB;
                border-radius: 8px;
                padding: 0.65rem 0.85rem;
                font-size: 0.9rem;
                font-family: 'DM Sans', sans-serif;
                background: white;
                transition: border-color .2s;
                outline: none;
            }

                .fg input:focus {
                    border-color: var(--navy2);
                }

                .fg input[readonly] {
                    background: #F3F4F6;
                    color: var(--muted);
                }

        .fg-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        .alert-error {
            background: #FEF2F2;
            color: var(--red);
            border: 1px solid #FECACA;
            border-radius: 8px;
            padding: 9px 13px;
            font-size: 0.78rem;
            margin-bottom: 1rem;
        }

        .dni-hint {
            background: #EFF6FF;
            color: var(--blue);
            border: 1px solid #BFDBFE;
            border-radius: 8px;
            padding: 9px 13px;
            font-size: 0.78rem;
            margin-bottom: 1rem;
        }

        .btn-primary {
            width: 100%;
            background: var(--navy);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.8rem;
            font-size: 0.9rem;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: opacity .2s;
            letter-spacing: 0.01em;
        }

            .btn-primary:hover {
                opacity: .85;
            }

        .btn-success {
            width: 100%;
            background: var(--green);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.8rem;
            font-size: 0.9rem;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-success:hover {
                opacity: .85;
            }

        .back-link {
            color: rgba(255,255,255,0.35);
            font-size: 0.75rem;
            text-decoration: none;
            transition: color .2s;
        }

            .back-link:hover {
                color: rgba(255,255,255,0.65);
            }

        .dni-input-big {
            font-size: 1.4rem !important;
            font-weight: 700 !important;
            letter-spacing: 0.15em;
            text-align: center;
            padding: 0.8rem !important;
        }
    </style>
</head>
<body>

    @if (tab == "empleado")
    {
        <!-- ══════════ FORMULARIO EMPLEADO ══════════ -->
        <div class="form-wrap">

            <div style="display:flex;align-items:center;gap:0.6rem;">
                <div class="logo-box" style="width:40px;height:40px;border-radius:10px;">
                    <img src="~/img/logo_argentum.jpeg" alt="Banco Argentum" />
                </div>
                <span style="color:white;font-weight:700;font-size:0.95rem;">Banco Argentum</span>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon blue">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             style="color:var(--blue)">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </div>
                    <div>
                        <div class="form-card-title">Acceso Empleados</div>
                        <div class="form-card-sub">Sistema interno de gestión</div>
                    </div>
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert-error">Usuario o contraseña incorrectos.</div>
                }

                <form asp-action="LoginEmpleado" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="fg">
                        <label>Usuario</label>
                        <input type="text" name="Username" placeholder="Ingrese su usuario" required autofocus autocomplete="username" />
                    </div>
                    <div class="fg" style="margin-bottom:1.25rem">
                        <label>Contraseña</label>
                        <input type="password" name="Password" placeholder="••••••••" required autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn-primary">Iniciar Sesión →</button>
                </form>
            </div>

            <a href="/Account/Login" class="back-link">← Cambiar tipo de acceso</a>
        </div>
    }
    else if (tab == "cliente")
    {
        <!-- ══════════ FORMULARIO CLIENTE — SOLO DNI ══════════ -->
        <div class="form-wrap">

            <div style="display:flex;align-items:center;gap:0.6rem;">
                <div class="logo-box" style="width:40px;height:40px;border-radius:10px;">
                    <img src="~/img/logo_argentum.jpeg" alt="Banco Argentum" />
                </div>
                <span style="color:white;font-weight:700;font-size:0.95rem;">Banco Argentum</span>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon blue">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             style="color:var(--blue)">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                    <div>
                        <div class="form-card-title">Obtener Turno</div>
                        <div class="form-card-sub">Ingrese su DNI para continuar</div>
                    </div>
                </div>

                @if (TempData["LoginError"] != null)
                {
                    <div class="alert-error">@TempData["LoginError"]</div>
                }

                <div class="dni-hint">
                     Ingrese su DNI
                </div>

                <form asp-action="DoLogin" asp-controller="Cliente" method="post">
                    @Html.AntiForgeryToken()
                    <div class="fg" style="margin-bottom:1.25rem">
                        <label>Número de DNI</label>
                        <input type="text"
                               name="dni"
                               class="dni-input-big"
                               placeholder="0000-0000-00000"
                               maxlength="13"
                               pattern="\d{13}"
                               inputmode="numeric"
                               oninput="this.value=this.value.replace(/\D/g,'')"
                               autofocus
                               required />
                    </div>
                    <button type="submit" class="btn-primary">Obtener Turno →</button>
                </form>
            </div>

            <a href="/Account/Login" class="back-link">← Cambiar tipo de acceso</a>
        </div>
    }
    else if (tab == "registro")
    {
        <!-- ══════════ REGISTRO RÁPIDO — SOLO NOMBRE Y APELLIDO ══════════ -->
        <div class="form-wrap">

            <div style="display:flex;align-items:center;gap:0.6rem;">
                <div class="logo-box" style="width:40px;height:40px;border-radius:10px;">
                    <img src="~/img/logo_argentum.jpeg" alt="Banco Argentum" />
                </div>
                <span style="color:white;font-weight:700;font-size:0.95rem;">Banco Argentum</span>
            </div>

            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon green">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             style="color:var(--green)">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <line x1="19" y1="8" x2="19" y2="14" />
                            <line x1="22" y1="11" x2="16" y2="11" />
                        </svg>
                    </div>
                    <div>
                        <div class="form-card-title">Primera visita</div>
                        <div class="form-card-sub">Solo necesitamos su nombre para registrarle</div>
                    </div>
                </div>

                @if (TempData["RegisterError"] != null)
                {
                    <div class="alert-error">@TempData["RegisterError"]</div>
                }

                <form asp-action="RegistroRapido" asp-controller="Cliente" method="post">
                    @Html.AntiForgeryToken()

                    <!-- DNI oculto y visible como solo lectura -->
                    <input type="hidden" name="dni" value="@TempData["DNIPendiente"]" />
                    <div class="fg">
                        <label>DNI</label>
                        <input type="text" value="@TempData["DNIPendiente"]" readonly />
                    </div>

                    <div class="fg-row">
                        <div class="fg">
                            <label>Nombre</label>
                            <input type="text" name="nombre" placeholder="María" autofocus required />
                        </div>
                        <div class="fg">
                            <label>Apellido</label>
                            <input type="text" name="apellido" placeholder="López" required />
                        </div>
                    </div>

                    <button type="submit" class="btn-success" style="margin-top:0.5rem">
                        Registrarme y obtener turno →
                    </button>
                </form>
            </div>

            <a href="/Account/Login?tab=cliente" class="back-link">← Volver a ingresar DNI</a>
        </div>
    }
    else
    {
        <!-- ══════════ SELECTOR: ¿Quién eres? ══════════ -->
        <div class="selector-wrap">

            <div class="logo-box">
                <img src="~/img/logo_argentum.jpeg" alt="Banco Argentum" />
            </div>

            <div class="selector-title">Banco Argentum</div>
            <div class="selector-sub">Sistema de Gestión de Turnos</div>

            <div class="selector-card">
                <h4>¿Cómo desea continuar?</h4>

                <a href="/Account/Login?tab=cliente" class="option-btn">
                    <div class="option-icon blue">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                    <div class="option-text">
                        <strong>Soy Cliente</strong>
                        <small>Solicitar un turno de atención</small>
                    </div>
                    <span class="option-arrow">›</span>
                </a>

                <a href="/Account/Login?tab=empleado" class="option-btn">
                    <div class="option-icon navy">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </div>
                    <div class="option-text">
                        <strong>Soy Empleado</strong>
                        <small>Acceder al sistema interno</small>
                    </div>
                    <span class="option-arrow">›</span>
                </a>
            </div>

            <div class="selector-footer" id="clock"></div>
        </div>

        <script>
            (function tick() {
                var d = new Date();
                var dias = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
                var meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
                var h = d.getHours().toString().padStart(2,'0');
                var m = d.getMinutes().toString().padStart(2,'0');
                document.getElementById('clock').textContent =
                    dias[d.getDay()] + ', ' + d.getDate() + ' de ' + meses[d.getMonth()] + ' de ' + d.getFullYear() + ' · ' + h + ':' + m;
                setTimeout(tick, 30000);
            })();
        </script>
    }

</body>
</html>
