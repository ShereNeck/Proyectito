@using Proyecto.Data.Entidades
@model IEnumerable<Servicio>
@{
    ViewData["Title"] = "Kiosco";
    var colores = new[] { "#1A56DB", "#16A34A", "#7C3AED", "#EA580C", "#0891B2", "#DC2626" };
    var svgPaths = new[] {
        "M2 6a2 2 0 012-2h12a2 2 0 012 2v1H2V6zm0 3h16v7a2 2 0 01-2 2H4a2 2 0 01-2-2V9zm11 3a1 1 0 100 2h2a1 1 0 100-2h-2z",
        "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7zM18 10h2m-1-1v2",
        "M3 6a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V6zm0 4h14M7 14h2",
        "M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
        "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
        "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
    };
    int idx = 0;
    string clienteNombre = ViewBag.ClienteNombre ?? "";
}

<div class="kl-body" style="align-items:flex-start;">
    <div style="width:100%;max-width:1100px;padding:0 16px;display:flex;flex-direction:column;gap:0;">

        <div class="kl-top-bar" style="margin-bottom:20px;">
            <div class="kl-brand">
                <div class="kl-brand-icon">A</div>
                <span>Banco Argentum</span>
            </div>
            <div style="display:flex;align-items:center;gap:12px;">
                <div id="kl-clock" class="kl-clock"></div>
                @if (!string.IsNullOrEmpty(clienteNombre))
                {
                    <div style="display:flex;align-items:center;gap:8px;background:white;border-radius:20px;padding:6px 14px;font-size:13px;color:var(--navy);font-weight:600;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
                        <div style="width:26px;height:26px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:11px;font-weight:700;">
                            @(clienteNombre.Length > 0 ? clienteNombre.Substring(0, 1).ToUpper() : "C")
                        </div>
                        @clienteNombre
                    </div>
                    <a href="/Cliente/Logout" style="font-size:12px;color:var(--gray);text-decoration:none;border:1px solid var(--border);border-radius:8px;padding:5px 10px;">Salir</a>
                }
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 300px;gap:20px;align-items:start;">

            <!-- ===== COLUMNA IZQUIERDA: Selección de servicio ===== -->
            <div class="kl-card" style="padding:28px;">
                <div style="margin-bottom:24px;">
                    <h2 style="font-size:22px;font-weight:700;color:var(--navy);margin:0 0 4px;">Seleccione el Servicio</h2>
                    <p style="font-size:13px;color:var(--gray);margin:0;">Elija el tipo de atención que necesita</p>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert-error" style="margin-bottom:16px;">⚠️ @TempData["Error"]</div>
                }

                <div class="kl-service-grid">
                    @foreach (var s in Model)
                    {
                        var color = colores[idx % colores.Length];
                        var path = svgPaths[idx % svgPaths.Length];
                        idx++;
                        <form method="post" asp-action="GenerarTicket" asp-controller="Kiosco" style="display:contents;">
                            <input type="hidden" name="servicioId" value="@s.ServicioId" />
                            <button type="submit" class="kl-srv-card">
                                <div class="kl-srv-icon" style="background:@color;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="@path" />
                                    </svg>
                                </div>
                                <div class="kl-srv-name">@s.Nombre_Servicio</div>
                                <div class="kl-srv-desc">@(s.Descripcion ?? "")</div>
                            </button>
                        </form>
                    }
                    @if (!Model.Any())
                    {
                        <p style="grid-column:span 2;text-align:center;color:var(--gray);padding:40px 0;">
                            No hay servicios disponibles en este momento.
                        </p>
                    }
                </div>
            </div>

            <!-- ===== COLUMNA DERECHA: Panel de turnos en tiempo real ===== -->
            <div style="display:flex;flex-direction:column;gap:12px;">

                <!-- Turno en atención -->
                <div style="background:#0D1B3E;border-radius:16px;padding:20px;text-align:center;">
                    <div style="font-size:10px;font-weight:700;letter-spacing:2px;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:10px;">Ahora Atendiendo</div>
                    <div id="currentTicketNum" style="font-size:42px;font-weight:800;color:#C9A84C;letter-spacing:2px;line-height:1;">---</div>
                    <div id="currentTicketSrv" style="font-size:12px;color:rgba(255,255,255,0.55);margin-top:6px;min-height:16px;"></div>
                    <div id="currentTicketVent" style="display:none;margin-top:8px;background:rgba(255,255,255,0.08);border-radius:8px;padding:4px 10px;font-size:11px;color:rgba(255,255,255,0.6);display:inline-block;"></div>
                </div>

                <!-- Lista de próximos turnos -->
                <div style="background:white;border-radius:16px;padding:16px;box-shadow:0 2px 12px rgba(0,0,0,0.06);">
                    <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;color:#6B7A99;text-transform:uppercase;margin-bottom:12px;">Próximos Turnos</div>
                    <div id="queueList">
                        <div style="text-align:center;color:#9CA3AF;font-size:12px;padding:20px 0;">
                            Sin turnos en espera
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        // Reloj
        function tick() {
            const n = new Date();
            document.getElementById('kl-clock').textContent =
                n.toLocaleTimeString('es', {hour:'2-digit', minute:'2-digit'}) + ' · ' +
                n.toLocaleDateString('es', {weekday:'short', day:'numeric', month:'short'});
        }
        setInterval(tick, 1000); tick();

        function renderQueue(data) {
            // Turno actual
            if (data.current) {
                document.getElementById('currentTicketNum').textContent = data.current.numeroTicket;
                document.getElementById('currentTicketSrv').textContent = data.current.servicio;
                var ventEl = document.getElementById('currentTicketVent');
                ventEl.textContent = data.current.ventanilla;
                ventEl.style.display = 'inline-block';
            } else {
                document.getElementById('currentTicketNum').textContent = '---';
                document.getElementById('currentTicketSrv').textContent = '';
                document.getElementById('currentTicketVent').style.display = 'none';
            }

            var list = document.getElementById('queueList');
            if (!data.queue || data.queue.length === 0) {
                list.innerHTML = '<div style="text-align:center;color:#9CA3AF;font-size:12px;padding:20px 0;">Sin turnos en espera</div>';
                return;
            }
            var html = '';
            data.queue.forEach(function(item) {
                html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #F3F4F6;">' +
                    '<div>' +
                        '<div style="font-size:16px;font-weight:800;color:#0D1B3E;">' + item.numeroTicket + '</div>' +
                        '<div style="font-size:11px;color:#6B7A99;margin-top:1px;">' + item.servicio + '</div>' +
                    '</div>' +
                    '<span style="font-size:10px;font-weight:600;background:#FEF3C7;color:#92400E;border-radius:6px;padding:3px 8px;">En espera</span>' +
                '</div>';
            });
            list.innerHTML = html;
        }

        fetch('/Sala/GetQueueData')
            .then(function(r) { return r.json(); })
            .then(renderQueue)
            .catch(function(e) { console.log('Cola no disponible', e); });

        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/queueHub")
            .build();

        connection.on("ReceiveQueueUpdate", function() {
            fetch('/Sala/GetQueueData')
                .then(function(r) { return r.json(); })
                .then(renderQueue);
        });

        connection.start().catch(function(err) { console.error(err.toString()); });
    </script>
}
