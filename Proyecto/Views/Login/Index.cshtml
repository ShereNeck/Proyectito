@{
    ViewData["Title"] = "Acceso Empleados";
}

<div class="login-body">
    <div class="login-card">
        <div class="login-logo">
            <div class="logo-big">A</div>
            <h2>Acceso Empleados</h2>
            <p>Sistema de Gestión de Turnos</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div style="background:#FEF2F2;color:#DC2626;border-radius:8px;padding:10px 14px;font-size:12px;margin-bottom:14px;">⚠️ @ViewBag.Error</div>
        }

        <form asp-action="Authenticate" method="post">
            <div class="form-group">
                <label>Usuario</label>
                <input type="text" name="username" placeholder="Ingrese su usuario" required />
            </div>
            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn-login">Iniciar Sesión</button>
        </form>

        <a href="/" style="display:block;text-align:center;margin-top:14px;font-size:13px;color:#6B7A99;text-decoration:none;">← Volver al inicio</a>
    </div>
</div>
