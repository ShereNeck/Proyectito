@{
    ViewData["Title"] = "Acceso Cliente";
    Layout = null;
    string tab = ViewBag.Tab ?? "login";
    string dniPendiente = TempData["DNIPendiente"]?.ToString() ?? "";
    if (!string.IsNullOrEmpty(dniPendiente)) tab = "registro";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Banco Argentum — Cliente</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="kl-body" style="background:linear-gradient(145deg,#0D1B3E 0%,#1A3070 100%);min-height:100vh;">
        <div style="width:100%;max-width:420px;padding:0 16px;">

            <!-- Logo -->
            <div style="text-align:center;margin-bottom:28px;">
                <div style="width:52px;height:52px;background:var(--gold);border-radius:12px;display:inline-flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;color:var(--navy);margin-bottom:12px;">A</div>
                <h2 style="color:white;font-size:20px;font-weight:700;margin:0 0 4px;">Banco Argentum</h2>
                <p style="color:rgba(255,255,255,0.5);font-size:13px;margin:0;">Área de Clientes</p>
            </div>

            <!-- Tarjeta -->
            <div style="background:white;border-radius:20px;padding:28px 28px 24px;box-shadow:0 24px 60px rgba(0,0,0,0.35);">

                <!-- === PANEL LOGIN: SOLO DNI === -->
                <div id="panel-login" style="display:@(tab == "login" ? "block" : "none")">
                    <div style="margin-bottom:20px;">
                        <h3 style="margin:0 0 4px;font-size:16px;color:#0D1B3E;">Ingrese su DNI</h3>
                        <p style="margin:0;font-size:13px;color:#6B7A99;">Si ya es cliente, el sistema lo reconocerá automáticamente.</p>
                    </div>
                    @if (TempData["LoginError"] != null)
                    {
                        <div style="background:#FEF2F2;color:#DC2626;border-radius:8px;padding:10px 14px;font-size:12px;margin-bottom:14px;">
                            ⚠️ @TempData["LoginError"]
                        </div>
                    }
                    <form method="post" asp-action="DoLogin" asp-controller="Cliente">
                        @Html.AntiForgeryToken()
                        <div class="modal-form-group" style="margin-bottom:20px;">
                            <label style="font-size:13px;font-weight:600;color:#374151;">DNI (13 dígitos)</label>
                            <input type="text" name="dni"
                                   placeholder="Ej: 0801200422317"
                                   maxlength="13" minlength="13"
                                   pattern="\d{13}"
                                   oninput="this.value=this.value.replace(/\D/g,'')"
                                   style="font-size:18px;letter-spacing:2px;text-align:center;"
                                   autofocus required />
                        </div>
                        <button type="submit" style="width:100%;background:#0D1B3E;color:white;border:none;border-radius:10px;padding:14px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">
                            Continuar →
                        </button>
                    </form>
                    <p style="text-align:center;margin-top:16px;font-size:12px;color:#6B7A99;">
                        ¿Primera vez? <button onclick="setTab('registro')" style="background:none;border:none;color:#1A3070;font-weight:600;cursor:pointer;font-size:12px;padding:0;">Regístrese aquí</button>
                    </p>
                </div>

                <!-- === PANEL REGISTRO: SOLO 3 CAMPOS === -->
                <div id="panel-registro" style="display:@(tab == "registro" ? "block" : "none")">
                    <div style="margin-bottom:20px;">
                        <h3 style="margin:0 0 4px;font-size:16px;color:#0D1B3E;">Nuevo cliente</h3>
                        <p style="margin:0;font-size:13px;color:#6B7A99;">Solo necesitamos sus datos básicos.</p>
                    </div>
                    @if (TempData["RegisterError"] != null)
                    {
                        <div style="background:#FEF2F2;color:#DC2626;border-radius:8px;padding:10px 14px;font-size:12px;margin-bottom:14px;">
                            ⚠️ @TempData["RegisterError"]
                        </div>
                    }
                    <form method="post" asp-action="RegistroRapido" asp-controller="Cliente">
                        @Html.AntiForgeryToken()
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                            <div class="modal-form-group">
                                <label style="font-size:13px;font-weight:600;color:#374151;">Nombre</label>
                                <input type="text" name="nombre" placeholder="María" required />
                            </div>
                            <div class="modal-form-group">
                                <label style="font-size:13px;font-weight:600;color:#374151;">Apellido</label>
                                <input type="text" name="apellido" placeholder="López" required />
                            </div>
                        </div>
                        <div class="modal-form-group" style="margin-bottom:20px;">
                            <label style="font-size:13px;font-weight:600;color:#374151;">DNI (13 dígitos)</label>
                            <input type="text" name="dni"
                                   value="@dniPendiente"
                                   placeholder="Ej: 0801200422317"
                                   maxlength="13" minlength="13"
                                   pattern="\d{13}"
                                   oninput="this.value=this.value.replace(/\D/g,'')"
                                   style="font-size:18px;letter-spacing:2px;text-align:center;"
                                   required />
                        </div>
                        <button type="submit" style="width:100%;background:#16A34A;color:white;border:none;border-radius:10px;padding:14px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">
                            Crear cuenta y continuar →
                        </button>
                    </form>
                    <p style="text-align:center;margin-top:16px;font-size:12px;color:#6B7A99;">
                        ¿Ya tiene cuenta? <button onclick="setTab('login')" style="background:none;border:none;color:#1A3070;font-weight:600;cursor:pointer;font-size:12px;padding:0;">Ingrese su DNI</button>
                    </p>
                </div>

            </div>

            <div style="text-align:center;margin-top:16px;">
                <a href="/" style="color:rgba(255,255,255,0.4);font-size:12px;text-decoration:none;">← Volver al inicio</a>
            </div>

        </div>
    </div>

    <script>
        function setTab(t) {
            var isLogin = t === 'login';
            document.getElementById('panel-login').style.display    = isLogin ? 'block' : 'none';
            document.getElementById('panel-registro').style.display = isLogin ? 'none'  : 'block';
        }
    </script>
</body>
</html>