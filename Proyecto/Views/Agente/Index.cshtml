@using Proyecto.Data.Entidades
@model IEnumerable<Ticket>
@{
    ViewData["Title"] = "Panel del Agente";
    var currentTicket = ViewBag.CurrentTicket as Ticket;
    var ventanillaId = ViewBag.VentanillaId;
    bool hasTicket = currentTicket != null;
    bool hasQueue  = Model != null && Model.Any();
}

<div class="agente-body">
    @if(TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="margin: 20px 24px 0 24px;">@TempData["Error"]</div>
    }

    @if(ViewBag.Error != null)
    {
        <div class="alert alert-warning" style="margin: 20px 24px;">@ViewBag.Error</div>
    }
    else
    {
        <div class="agente-content">
            <div class="agente-card">
                <div class="agente-card-header">
                    Turno Actual
                    @if(hasTicket){ <span class="badge">EN ATENCIÓN</span> } else { <span class="badge" style="background:#ddd;">LIBRE</span> }
                </div>
                <div class="agente-card-body">
                    <div class="current-ticket">
                        @if(hasTicket)
                        {
                            <div class="big-num">@currentTicket.Numero_Ticket</div>
                            var waitTime = Math.Round((currentTicket.Hora_Atencion.Value - currentTicket.Hora_Emision).TotalMinutes);
                            <div class="ticket-info">Emitido: @currentTicket.Hora_Emision.ToLocalTime().ToString("HH:mm") — Espera: @waitTime min</div>
                            <div class="ticket-service">@currentTicket.Servicio?.Nombre_Servicio</div>
                        }
                        else
                        {
                            <div class="big-num" style="color:#ddd;">---</div>
                            <div class="ticket-info">No hay turno en atención.</div>
                        }
                    </div>

                    <div class="action-btns">
                        <form asp-action="LlamarDeNuevo" method="post" style="display:contents">
                            <input type="hidden" name="ticketId" value="@(currentTicket?.TicketId ?? Guid.Empty)" />
                            <button type="submit" class="btn btn-primary" disabled="@(!hasTicket)">Llamar de nuevo</button>
                        </form>
                        <form asp-action="FinalizarTicket" method="post" style="display:contents">
                            <input type="hidden" name="ticketId" value="@(currentTicket?.TicketId ?? Guid.Empty)" />
                            <button type="submit" class="btn btn-success" disabled="@(!hasTicket)">Finalizar</button>
                        </form>
                        <form asp-action="MarcarAusente" method="post" style="display:contents">
                            <input type="hidden" name="ticketId" value="@(currentTicket?.TicketId ?? Guid.Empty)" />
                            <button type="submit" class="btn btn-danger" disabled="@(!hasTicket)">Ausente</button>
                        </form>
                        <form asp-action="LlamarSiguiente" method="post" style="display:contents">
                            <input type="hidden" name="ventanillaId" value="@ventanillaId" />
                            <button type="submit" class="btn btn-siguiente" disabled="@(hasTicket || !hasQueue)">Siguiente</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="agente-card">
                <div class="agente-card-header">
                    Cola de Espera (Compatible)
                    <span class="badge" style="background:var(--navy);border:1px solid rgba(255,255,255,0.2);color:white;">@Model?.Count() pendientes</span>
                </div>
                <div class="agente-card-body">
                    <div class="queue-list">
                        @if(hasQueue)
                        {
                            foreach(var ticket in Model)
                            {
                                var waitTicks = (DateTime.UtcNow - ticket.Hora_Emision).TotalMinutes;
                                var prioNombre = ticket.Cola?.Prioridad?.Nombre ?? "Normal";
                                var pillClass = prioNombre switch {
                                    "Preferencial" => "pill-pref",
                                    "VIP"          => "pill-active",
                                    _              => "pill-wait"
                                };
                                <div class="queue-row">
                                    <span class="qn">@ticket.Numero_Ticket</span>
                                    <span class="qs">@ticket.Servicio?.Nombre_Servicio</span>
                                    <span class="qt">@Math.Round(waitTicks) min</span>
                                    <span class="status-pill @pillClass">@prioNombre</span>
                                    @if(prioNombre == "Normal")
                                    {
                                        <form asp-action="PromoverTicket" method="post" style="display:contents">
                                            <input type="hidden" name="ticketId" value="@ticket.TicketId" />
                                            <button type="submit" class="btn-promover">▲ Preferencial</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn-promover" style="visibility:hidden;" disabled>▲ Preferencial</button>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="queue-row justify-content-center text-muted">No hay tickets compatibles en espera.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
